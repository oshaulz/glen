# Nim build cache & compiler artefacts
nimcache/
nimblecache-*/

# Native object / binary outputs
*.o
*.obj
*.dll
*.so
*.dylib
*.pdb
*.exe
*.dSYM/

# OS
.DS_Store
Thumbs.db

# Editor / tooling
.vscode/
.idea/
.claude/

# Env
.env
.env.*

# Generated docs from `nimble docs` (HTML output drops into /docs/). Keep
# our hand-written Markdown documentation tracked.
/docs/*.html
/docs/**/*.html
/docs/theindex.html
/docs/htmldocs/

# Compiled Nim test binaries — keep *.nim sources, ignore executables.
tests/test_*
!tests/*.nim

# Compiled example binaries. Each example file in examples/foo.nim produces
# an executable at examples/foo with no extension. List them explicitly so
# stray files in examples/ aren't hidden by a wildcard.
/examples/basic
/examples/crud_validated
/examples/todo_sync

# Glen on-disk databases created by examples & ad-hoc usage at the repo root.
# Layout: glen.wal.<n>, <collection>.snap, node.id, peers.state.
/exampledb/
/crud_example_db/
/glen.wal.*
/*.snap
/node.id
/peers.state
